rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: master_siswa
    // Fields:
    //   - Nama: string (required)
    //   - Kelas: string (required)
    //
    // Collection: absensi_log
    // Fields:
    //   - id: string (required)
    //   - tanggal: string (required, YYYY-MM-DD)
    //   - nama: string (required)
    //   - kelas: string (required)
    //   - keterangan: string (required, Sakit/Izin/Alpha)
    //   - bukti: string (optional)
    //   - penanggungJawab: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: kalender_pendidikan
    // Fields:
    //   - date: string (required, YYYY-MM-DD)
    //   - name: string (required)
    //   - type: string (required, nasional/semester/fakultatif)
    //
    // Collection: izin_wali
    // Fields:
    //   - tanggal: string (required, YYYY-MM-DD)
    //   - kelas: string (required)
    //   - namaSiswa: string (required)
    //   - jenisIzin: string (required, Sakit/Izin)
    //   - namaWali: string (required)
    //   - telpWali: string (required)
    //   - keterangan: string (required)
    //   - lampiran: string (required)
    //   - statusInput: boolean (required)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         exists(/databases/$(database)/documents/admin_emails/$(request.auth.token.email)) ||
          (request.auth.token.email == "wiwikismiati61@guru.smp.belajar.id" && request.auth.token.email_verified == true));
    }

    function isValidSiswa(data) {
      return data.keys().hasAll(['Nama', 'Kelas']) &&
             data.Nama is string && data.Nama.size() > 0 && data.Nama.size() < 100 &&
             data.Kelas is string && data.Kelas.size() > 0 && data.Kelas.size() < 20;
    }

    function isValidAbsensi(data) {
      return data.keys().hasAll(['tanggal', 'nama', 'kelas', 'keterangan']) &&
             data.tanggal is string && data.tanggal.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.nama is string && data.nama.size() > 0 && data.nama.size() < 100 &&
             data.kelas is string && data.kelas.size() > 0 && data.kelas.size() < 20 &&
             data.keterangan in ['Sakit', 'Izin', 'Alpha', ''] &&
             (!('penanggungJawab' in data) || (data.penanggungJawab is string && data.penanggungJawab.size() < 100));
    }

    function isValidHoliday(data) {
      return data.keys().hasAll(['date', 'name', 'type']) &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.type in ['nasional', 'semester', 'fakultatif'];
    }

    function isValidIzinWali(data) {
      return data.keys().hasAll(['tanggal', 'kelas', 'namaSiswa', 'jenisIzin', 'namaWali', 'telpWali', 'keterangan', 'lampiran', 'statusInput']) &&
             data.tanggal is string && data.tanggal.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.kelas is string && data.kelas.size() > 0 && data.kelas.size() < 20 &&
             data.namaSiswa is string && data.namaSiswa.size() > 0 && data.namaSiswa.size() < 100 &&
             data.jenisIzin in ['Sakit', 'Izin'] &&
             data.namaWali is string && data.namaWali.size() > 0 && data.namaWali.size() < 100 &&
             data.telpWali is string && data.telpWali.size() > 0 && data.telpWali.size() < 20 &&
             data.keterangan is string && data.keterangan.size() > 0 && data.keterangan.size() < 1000 &&
             data.lampiran is string && data.lampiran.size() > 0 && data.lampiran.size() < 2000000 && // ~2MB base64 limit
             data.statusInput is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /master_siswa/{siswaId} {
      // Public read for dashboard charts, Admin only write
      allow read: if true;
      allow write: if isAdmin();
    }

    match /absensi_log/{absensiId} {
      // Dashboard needs public read as per user request "membuka dashboard tidak perlu login"
      allow read: if true; 
      // Only admin can write
      allow write: if isAdmin();
    }

    match /kalender_pendidikan/{holidayId} {
      allow read: if true;
      allow write: if isAdmin() && isValidHoliday(request.resource.data);
      allow delete: if isAdmin();
    }

    match /izin_wali/{izinId} {
      allow read: if isAdmin();
      allow create: if isValidIzinWali(request.resource.data) && request.resource.data.statusInput == false;
      allow update: if isAdmin() && isValidIzinWali(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /admin_emails/{emailId} {
      allow read: if isAuthenticated() && (request.auth.token.email == emailId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
