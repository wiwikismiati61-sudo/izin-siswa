{
  "entities": {
    "Siswa": {
      "title": "Siswa",
      "description": "Data master siswa",
      "type": "object",
      "properties": {
        "Nama": {
          "type": "string",
          "description": "Nama lengkap siswa"
        },
        "Kelas": {
          "type": "string",
          "description": "Kelas siswa"
        }
      },
      "required": ["Nama", "Kelas"]
    },
    "AbsensiEntry": {
      "title": "AbsensiEntry",
      "description": "Log absensi harian",
      "type": "object",
      "properties": {
        "tanggal": {
          "type": "string",
          "description": "Tanggal absensi (YYYY-MM-DD)"
        },
        "nama": {
          "type": "string",
          "description": "Nama siswa"
        },
        "kelas": {
          "type": "string",
          "description": "Kelas siswa"
        },
        "keterangan": {
          "type": "string",
          "enum": ["Sakit", "Izin", "Alpha"],
          "description": "Status kehadiran"
        },
        "bukti": {
          "type": "string",
          "description": "URL bukti (jika ada)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Waktu pembuatan data"
        }
      },
      "required": ["tanggal", "nama", "kelas", "keterangan"]
    },
    "Holiday": {
      "title": "Holiday",
      "description": "Data hari libur kalender pendidikan",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "Tanggal libur (YYYY-MM-DD)"
        },
        "name": {
          "type": "string",
          "description": "Nama hari libur"
        },
        "type": {
          "type": "string",
          "enum": ["nasional", "semester", "fakultatif"],
          "description": "Tipe hari libur"
        }
      },
      "required": ["date", "name", "type"]
    }
  },
  "firestore": {
    "/master_siswa/{siswaId}": {
      "schema": "Siswa",
      "description": "Koleksi data master siswa"
    },
    "/absensi_log/{absensiId}": {
      "schema": "AbsensiEntry",
      "description": "Koleksi log absensi harian"
    },
    "/kalender_pendidikan/{holidayId}": {
      "schema": "Holiday",
      "description": "Koleksi data hari libur kalender pendidikan"
    }
  }
}
